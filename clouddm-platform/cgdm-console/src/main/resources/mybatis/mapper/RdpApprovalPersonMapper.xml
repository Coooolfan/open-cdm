<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.console.web.dal.mapper.RdpApprovalPersonMapper">

    <resultMap id="rdpApprovalPersonDO" type="com.clougence.clouddm.console.web.dal.model.RdpApprovalPersonDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="ticket_bz_id" property="ticketBzId"/>
        <result column="person_uid" property="personUid"/>
    </resultMap>

    <sql id="rdpApprovalPersonList">
        id,
        gmt_create,
        gmt_modified,
        ticket_bz_id,
        person_uid
    </sql>

    <insert id="insertTemplateBatch">
        insert into rdp_approval_person
        (ticket_bz_id, person_uid)
        values
        <foreach collection="cacheList" item="item" separator=",">
            (
            #{item.ticketBzId},
            #{item.personUid}
            )
        </foreach>
    </insert>

    <delete id="deleteByTicketBzId">
        delete
        from
            rdp_approval_person
        where
            ticket_bz_id = #{ticketBzId}
    </delete>

    <select id="queryByTicketBzId" resultType="com.clougence.clouddm.console.web.dal.model.RdpApprovalPersonDO">
        select
            <include refid="rdpApprovalPersonList"/>
        from
             rdp_approval_person
        where
             ticket_bz_id = #{ticketBzId}
    </select>

</mapper>
