<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.console.web.dal.mapper.DmApprovalProcessActivityMapper">

    <resultMap id="DmApprovalProcessActivityDO" type="com.clougence.clouddm.console.web.dal.model.DmApprovalProcessActivityDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="activity_id" property="activityId"/>
        <result column="process_id" property="processId"/>
        <result column="activity_title" property="activityTitle"/>
        <result column="ticket_id" property="ticketId"/>
        <result column="order_number" property="orderNumber"/>
        <result column="context" property="context"/>
    </resultMap>

    <sql id="all_col">
        id,
        gmt_create,
        gmt_modified,
        activity_id,
        process_id,
        ticket_id,
        activity_title,
        order_number,
        context
    </sql>

    <update id="updateContext">
        update dm_approval_process_activity
        set context = #{context}
        where process_id = #{processId}
          and activity_id = #{activityId}
    </update>

    <select id="queryByTicketId" resultType="com.clougence.clouddm.console.web.dal.model.DmApprovalProcessActivityDO">
        select
        <include refid="all_col"/>
        from dm_approval_process_activity
        where ticket_id = #{ticketId}
        order by order_number asc
    </select>

    <select id="queryByProcessIdAndActivityIdForUpdate"
            resultType="com.clougence.clouddm.console.web.dal.model.DmApprovalProcessActivityDO">
        select
        <include refid="all_col"/>
        from dm_approval_process_activity
        where process_id = #{processId}
        and activity_id = #{activityId}
        for update
    </select>


</mapper>
