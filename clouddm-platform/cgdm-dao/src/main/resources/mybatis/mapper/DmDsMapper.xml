    <select id="listByUser" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSourceIdentity"/>
        FROM
            dm_ds
        WHERE
            uid = #{uid} and
            life_cycle_state != 'DELETED'
        ORDER BY
            data_source_type asc
    </select>

    <select id="listByUserWithGmtOrder" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSourceIdentity"/>
        FROM
            dm_ds
        WHERE
            uid = #{uid} and
            life_cycle_state != 'DELETED'
        ORDER BY
            gmt_create DESC
    </select>

    <select id="listByUidAndEnvId" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSourceIdentity"/>
        FROM
            dm_ds
        WHERE
            life_cycle_state != 'DELETED' and
            ds_env_id = #{envId} and
            uid = #{uid}
        ORDER BY data_source_type asc
    </select>

    <select id="listByDsIdsAndEnvId" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSourceIdentity"/>
        FROM
            dm_ds
        WHERE
            life_cycle_state != 'DELETED' and
            ds_env_id = #{envId} and
            id in <foreach collection="ids" item="item" separator="," open="(" close=")">#{item}</foreach>
        ORDER BY data_source_type asc
    </select>

    <select id="queryDsIdentityById" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSourceIdentity"/>
        FROM
            dm_ds
        WHERE
            id=#{id}
    </select>

    <select id="listByDesc" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSource"/>
        FROM
            dm_ds
        WHERE
            life_cycle_state != 'DELETED'
        and
            instance_desc like CONCAT('%',#{dataSourceDesc},'%')
        ORDER BY gmt_create DESC
    </select>

