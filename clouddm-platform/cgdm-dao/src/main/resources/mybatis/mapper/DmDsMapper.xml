    <select id="queryOneByUid" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSource"/>
        FROM
            dm_ds
        WHERE
            uid = #{uid}
        limit 1
    </select>

    <select id="queryCurrentDsTypes" resultType="com.clougence.clouddm.base.metadata.ds.DataSourceType">
        select data_source_type
        from dm_ds;
    </select>

    <update id="cleanDataSourceAccount">
        UPDATE
            dm_ds
        SET account  = null,
            password = null
        WHERE id = #{id}
    </update>

    <update id="updateAccountAndPasswordById">
        UPDATE
            dm_ds
        SET account  = #{account},
            password = #{password}
        WHERE id = #{id}
    </update>

    <update id="updateSecurityInfo">
        UPDATE
            dm_ds
        SET account      = #{account},
            password     = #{password},
            security_type=#{securityType}
        WHERE id = #{id}
    </update>

    <update id="updateSecurityAllInfo">
        UPDATE
            dm_ds
        SET
            account = #{account},
            password = #{password},
            security_type = #{securityType},
            access_key = #{accessKey},
            secret_key = #{secretKey}
            <if test="storeType != null">
                ,security_file_store_type = #{storeType,javaType=com.clougence.clouddm.platform.dal.model.datasource.SecurityFileStoreType}
            </if>
            <if test="securityFileUrl != null">
                ,security_file_url = #{securityFileUrl}
            </if>
            <if test="securityFilePassword != null">
                ,security_file_password = #{securityFilePassword}
            </if>
            <if test="clientSecurityFileUrl != null">
                ,client_security_file_url = #{clientSecurityFileUrl}
            </if>
            <if test="clientSecurityFilePassword != null">
                ,client_security_file_password = #{clientSecurityFilePassword}
            </if>
            <if test="secretFileUrl != null">
                ,secret_file_url = #{secretFileUrl}
            </if>
            <if test="secretFilePassword != null">
                ,secret_file_password = #{secretFilePassword}
            </if>
        WHERE
            id = #{id}
    </update>

    <update id="updateAkAndSk">
        UPDATE
            dm_ds
        SET
            access_key = #{accessKey},
            secret_key = #{secretKey}
        WHERE
