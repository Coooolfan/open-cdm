    <select id="getByInstanceId" resultMap="rdpDataSourceDO">
        SELECT
            <include refid="rdpDataSource"/>
        FROM
            dm_ds
        WHERE
            life_cycle_state != 'DELETED' AND
            instance_id = #{instanceId}
        ORDER BY gmt_create DESC
