    <sql id="rdpDataSource">
        id,
        gmt_create,
        gmt_modified,
        uid,
        owner,
        deploy_type,
        info_fetch_type,
        data_source_type,
        host,
        private_host,
        public_host,
        host_type,
        instance_desc,
        version,
        driver,
        instance_id,
        account,
        password,
        access_key,
        secret_key,
        security_file_url,
        security_file_password,
        client_security_file_url,
        client_security_file_password,
        secret_file_password,
        secret_file_url,
        security_file_store_type,
        security_type,
        public_security_type,
        client_trust_store_password,
        life_cycle_state,
        console_job_id,
        parent_ds_id,
        connect_type,
        ds_env_id,
        default_db_name
