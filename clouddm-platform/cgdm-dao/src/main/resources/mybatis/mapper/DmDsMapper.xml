    <update id="updateAliyunRdsAkAndSk">
        UPDATE
            dm_ds
        SET
            access_key = #{accessKey},
            secret_key = #{secretKey}
        WHERE
            id = #{id} AND
            deploy_type = 'ALIBABA_CLOUD_HOSTED'
    </update>

