    <sql id="rdpDataSourceIdentity">
        id,
        gmt_create,
        gmt_modified,
        uid,
        owner,
        deploy_type,
        info_fetch_type,
        data_source_type,
        host,
        private_host,
        public_host,
        host_type,
        instance_desc,
        version,
        ds_env_id,
        instance_id
