    <select id="listByCondition" resultMap="rdpDataSourceDO" parameterType="com.clougence.clouddm.platform.dal.model.datasource.ArgDsQueryParamObj">
        SELECT
            <include refid="rdpDataSource"/>
        FROM
            dm_ds
        WHERE
            life_cycle_state != 'DELETED'
            <if test="dataSourceType != null">
                AND data_source_type = #{dataSourceType,javaType=com.clougence.clouddm.base.metadata.ds.DataSourceType}
            </if>
            <if test="deployType != null">
                AND deploy_type = #{deployType,javaType=com.clougence.clouddm.platform.dal.model.datasource.DeployEnvType}
            </if>
            <if test="lifeCycleState != null">
                AND life_cycle_state = #{lifeCycleState,javaType=com.clougence.clouddm.platform.dal.model.LifeCycleState}
            </if>
            <if test="dataSourceIds != null and dataSourceIds.size > 0">
                AND id IN <foreach collection="dataSourceIds" item="item" separator="," open="(" close=")">#{item}</foreach>
            </if>
            <if test="dataSourceDescLike != null">
                AND instance_desc LIKE concat('%',#{dataSourceDescLike},'%')
            </if>
            <if test="dsHostLike != null">
                AND host  LIKE concat('%',#{dsHostLike},'%')
            </if>
            <if test="instanceIdLike != null">
                AND instance_id  LIKE concat('%',#{instanceIdLike},'%')
            </if>
        ORDER BY gmt_create DESC
    </select>

