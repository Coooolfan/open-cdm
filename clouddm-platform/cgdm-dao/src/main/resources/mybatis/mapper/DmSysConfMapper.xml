<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.system.DmSysConfMapper">

    <resultMap id="rdpSystemConfigDO" type="com.clougence.clouddm.platform.dal.model.system.DmSysConfDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="uid" property="uid"/>
        <result column="config_name" property="configName"/>
        <result column="config_value" property="configValue"/>
        <result column="description" property="description"/>
    </resultMap>

    <sql id="rdpSystemConfig">
        dm_sys_conf.id id,
        dm_sys_conf.gmt_create gmt_create,
        dm_sys_conf.gmt_modified gmt_modified,
        dm_sys_conf.uid uid,
        dm_sys_conf.config_name config_name,
        dm_sys_conf.config_value config_value,
        dm_sys_conf.description description
    </sql>

    <select id="queryByUid" resultMap="rdpSystemConfigDO">
        SELECT
        <include refid="rdpSystemConfig"/>
        FROM
        dm_sys_conf
        WHERE
        uid = #{uid}
    </select>

    <select id="queryEmptyUidConf" resultMap="rdpSystemConfigDO">
        SELECT
        <include refid="rdpSystemConfig"/>
        FROM
        dm_sys_conf
        WHERE
        uid is null;
    </select>

    <select id="queryByConfigName" resultMap="rdpSystemConfigDO">
        SELECT
        <include refid="rdpSystemConfig"/>
        FROM
        dm_sys_conf
        WHERE
        config_name = #{configName} and uid = #{uid}
    </select>

    <update id="updateUserConfig">
        UPDATE
            dm_sys_conf
        SET config_value = #{configValue}
        WHERE uid = #{uid}
          and config_name = #{configName}
    </update>
</mapper>
