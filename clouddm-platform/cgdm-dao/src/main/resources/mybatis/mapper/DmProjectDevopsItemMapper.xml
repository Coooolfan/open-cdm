<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.project.DmProjectDevopsItemMapper">
    <resultMap id="dmProjectDevopsItemDO" type="com.clougence.clouddm.platform.dal.model.project.DmProjectDevopsItemDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="owner_uid" property="ownerUid"/>
        <result column="ref_project_id" property="refProjectId"/>
        <result column="ref_devops_id" property="refDevopsId"/>
        <result column="content_name" property="contentName"/>
        <result column="content_index" property="contentIndex"/>
        <result column="content" property="content"/>
    </resultMap>

    <sql id="dmProjectDevopsItemDO_select">
        id,
        gmt_create,
        gmt_modified,
        owner_uid,
        ref_project_id,
        ref_devops_id,
        content_name,
        content_index,
        content
    </sql>

    <select id="queryItemByDevopsId" resultMap="dmProjectDevopsItemDO">
        select
            <include refid="dmProjectDevopsItemDO_select"/>
        from
            dm_project_devops_item
        where
            owner_uid            = #{ownerUid} and
            ref_devops_id        = #{devopsId}
        order by
            content_index asc
    </select>

    <delete id="deleteItemByDevopsId">
        delete from
            dm_project_devops_item
        where
            owner_uid            = #{ownerUid} and
            ref_devops_id        = #{devopsId}
    </delete>
</mapper>
