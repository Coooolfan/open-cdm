<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.project.DmProjectChangeItemMapper">
    <resultMap id="dmProjectChangeItemDO" type="com.clougence.clouddm.platform.dal.model.project.DmProjectChangeItemDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="owner_uid" property="ownerUid"/>
        <result column="ref_project_id" property="refProjectId"/>
        <result column="ref_change_id" property="refChangeId"/>
        <result column="ref_change_item_type" property="changeItemType" javaType="com.clougence.clouddm.platform.dal.model.project.ChangeItemType"/>
        <result column="content_name" property="contentName"/>
        <result column="content_index" property="contentIndex"/>
        <result column="content" property="content"/>
    </resultMap>

    <sql id="dmProjectChangeItemDO_select">
        id,
        gmt_create,
        gmt_modified,
        owner_uid,
        ref_project_id,
        ref_change_id,
        ref_change_item_type,
        content_name,
        content_index,
        content
    </sql>

    <select id="queryChangeItemByChangeId" resultMap="dmProjectChangeItemDO">
        select
            <include refid="dmProjectChangeItemDO_select"/>
        from
            dm_project_change_item
        where
            owner_uid            = #{ownerUid}    and
            ref_change_id        = #{refChangeId} and
            ref_change_item_type = #{itemType,javaType= com.clougence.clouddm.platform.dal.model.project.ChangeItemType}
        order by
            content_index asc
    </select>

    <delete id="deleteByChangeItemType">
        delete from
            dm_project_change_item
        where
            owner_uid            = #{ownerUid}    and
            ref_change_id        = #{refChangeId} and
            ref_change_item_type = #{itemType,javaType= com.clougence.clouddm.platform.dal.model.project.ChangeItemType}
    </delete>

    <delete id="deleteByChangeItemAll">
        delete from
            dm_project_change_item
        where
            owner_uid            = #{ownerUid}    and
            ref_change_id        = #{refChangeId}
    </delete>
</mapper>
