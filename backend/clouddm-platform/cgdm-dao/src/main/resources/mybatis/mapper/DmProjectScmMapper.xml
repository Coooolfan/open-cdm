<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.project.DmProjectScmMapper">
    <resultMap id="dmProjectScmDO" type="com.clougence.clouddm.platform.dal.model.project.DmProjectScmDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="owner_uid" property="ownerUid"/>
        <result column="scm_type" property="scmType" javaType="com.clougence.clouddm.platform.dal.model.project.ScmType"/>
        <result column="scm_display" property="scmDisplay"/>
        <result column="scm_service_url" property="scmServiceUrl"/>
        <result column="scm_access_token" property="scmAccessToken"/>
    </resultMap>

    <sql id="dmProjectScmDO_select">
        id,
        gmt_create,
        gmt_modified,
        owner_uid,
        scm_type,
        scm_display,
        scm_service_url,
        scm_access_token
    </sql>

    <select id="queryListByOwner" resultMap="dmProjectScmDO">
        select
            <include refid="dmProjectScmDO_select"/>
        from
            dm_project_scm
        where
            owner_uid = #{ownerUid}
        order by
            scm_type asc, gmt_create asc
    </select>

    <select id="queryListByOwnerAndIds" resultMap="dmProjectScmDO">
        select
            <include refid="dmProjectScmDO_select"/>
        from
            dm_project_scm
        where
            owner_uid = #{ownerUid} and
            id in <foreach collection="ids" item="item" separator="," open="(" close=")">#{item}</foreach>
        order by
            scm_type asc, gmt_create asc
    </select>

    <select id="queryById" resultMap="dmProjectScmDO">
        select
            <include refid="dmProjectScmDO_select"/>
        from
            dm_project_scm
        where
            id = #{scmId}
        limit 1
    </select>

    <delete id="deleteByOwnerAndId">
        delete from
            dm_project_scm
        where
            id = #{scmId} and owner_uid = #{ownerUid}
    </delete>

    <update id="updateDisplayByOwnerAndId">
        update
            dm_project_scm
        set
            scm_display  = #{newData},
            gmt_modified = now()
        where
            id = #{scmId} and owner_uid = #{ownerUid}
    </update>

    <update id="updateServiceUrlByOwnerAndId">
        update
            dm_project_scm
        set
            scm_service_url = #{newData},
            gmt_modified    = now()
        where
            id = #{scmId} and owner_uid = #{ownerUid}
    </update>

    <update id="updateAccessTokenByOwnerAndId">
        update
            dm_project_scm
        set
            scm_access_token = #{newData},
            gmt_modified     = now()
        where
            id = #{scmId} and owner_uid = #{ownerUid}
    </update>
</mapper>
