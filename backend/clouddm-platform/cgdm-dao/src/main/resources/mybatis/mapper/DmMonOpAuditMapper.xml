        </if>
        <if test="userNameLike != null and userNameLike != ''">
            <![CDATA[ AND user_name like CONCAT('%',#{userNameLike},'%') ]]>
        </if>
        ORDER BY operate_date DESC,id LIMIT #{pageSize} OFFSET #{offset}
    </select>
</mapper>
