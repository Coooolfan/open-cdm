    <select id="querySection" resultType="com.clougence.clouddm.platform.dal.model.monitor.DmMonOpAuditDO">
        SELECT
            <include refid="rdpOperationAudit"/>
        FROM
            dm_mon_op_audit
        WHERE 1=1
        <if test="startId != 0">
            <![CDATA[ AND id < #{startId} ]]>
        </if>
        ORDER BY operate_date DESC,id limit #{pageSize}
    </select>

    <select id="queryByCondition" resultType="com.clougence.clouddm.platform.dal.model.monitor.DmMonOpAuditDO">
        SELECT
        <include refid="rdpOperationAudit"/>
        FROM
        dm_mon_op_audit
        WHERE 1=1
        AND owner_uid = #{puid}
        <if test="startId != 0">
            <![CDATA[ AND id < #{startId} ]]>
        </if>
        <if test="uid != null and uid != ''">
            AND uid = #{uid}
        </if>
        <if test="dateStart != null">
            <![CDATA[ AND operate_date >= #{dateStart} ]]>
        </if>
        <if test="dateEnd != null">
            <![CDATA[ AND operate_date <= #{dateEnd} ]]>
        </if>
        <if test="securityLevel != null">
            <![CDATA[ AND security_level = #{securityLevel} ]]>
        </if>
        <if test="auditType != null">
            <![CDATA[ AND audit_type = #{auditType} ]]>
        </if>
        <if test="resourceType != null">
            <![CDATA[ AND resource_type = #{resourceType} ]]>
        </if>
        <if test="userNameLike != null and userNameLike != ''">
            <![CDATA[ AND user_name like CONCAT('%',#{userNameLike},'%') ]]>
        </if>
        ORDER BY operate_date DESC,id LIMIT #{pageSize}
    </select>

    <select id="pageByCondition" resultType="com.clougence.clouddm.platform.dal.model.monitor.DmMonOpAuditDO">
        SELECT
        <include refid="rdpOperationAudit"/>
        FROM
        dm_mon_op_audit
        WHERE 1=1
        AND owner_uid = #{puid}
        <if test="uid != null and uid != ''">
            AND uid = #{uid}
        </if>
        <if test="dateStart != null">
            <![CDATA[ AND operate_date >= #{dateStart} ]]>
        </if>
        <if test="dateEnd != null">
            <![CDATA[ AND operate_date <= #{dateEnd} ]]>
        </if>
        <if test="securityLevel != null">
            <![CDATA[ AND security_level = #{securityLevel} ]]>
