<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.execution.DmExecQueryConstraintsMapper">

    <resultMap id="constraintDO" type="com.clougence.clouddm.platform.dal.model.execution.DmExecQueryConstraintsDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="primary_uid" property="primaryUid"/>
        <result column="ds_id" property="dsId"/>
        <result column="path" property="path"/>
        <result column="constraints_json" property="constraints"  typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
    </resultMap>

    <sql id="allColumns">
        id,
        gmt_create,
        gmt_modified,
        primary_uid,
        ds_id,
        path,
        constraints_json
    </sql>

    <select id="selectAllByUid" resultMap="constraintDO">
        SELECT
        <include refid="allColumns"/>
        FROM
        dm_exec_query_constraints
        WHERE
        primary_uid = #{primaryUid}
        and ds_id = #{dsId}
        and path in <foreach collection="paths" item="item" separator="," open="(" close=")">#{item}</foreach>
    </select>

</mapper>