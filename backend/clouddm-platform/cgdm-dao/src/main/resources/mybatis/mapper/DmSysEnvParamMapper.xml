<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.system.DmSysEnvParamMapper">

    <resultMap id="rdpEnvParamDO" type="com.clougence.clouddm.platform.dal.model.system.DmSysEnvParamDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="env_id" property="envId"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="primary_uid" property="primaryUid"/>
    </resultMap>

    <sql id="rdpEnvParamList">
        id,
        gmt_create,
        gmt_modified,
        env_id,
        config_key,
        config_value,
        primary_uid
    </sql>

    <delete id="deleteEnvParam">
        delete from dm_sys_env_param where config_key = #{paramKey} and env_id = #{envId} and primary_uid = #{puid}
    </delete>

    <select id="queryByParamKey" resultMap="rdpEnvParamDO">
        select
            <include refid="rdpEnvParamList"/>
        from
            dm_sys_env_param
        where
            primary_uid = #{puid} and
            config_key  = #{paramKey} and
            env_id      = #{envId}
        limit 1
    </select>

    <select id="queryByParamKeySet" resultMap="rdpEnvParamDO">
        select
            <include refid="rdpEnvParamList"/>
        from
            dm_sys_env_param
        <where>
            primary_uid = #{puid}
            and config_key in <foreach collection="paramKeys" item="item" separator="," open="(" close=")">#{item}</foreach>
        </where>
    </select>

    <select id="queryByEnvIdAndPUid" resultMap="rdpEnvParamDO">
        select
            <include refid="rdpEnvParamList"/>
        from
            dm_sys_env_param
        <where>
            env_id = #{envId}
            and primary_uid = #{puid}
        </where>
    </select>

    <select id="queryByUid" resultMap="rdpEnvParamDO">
        select
            <include refid="rdpEnvParamList"/>
        from
            dm_sys_env_param
        <where>
           primary_uid = #{puid}
        </where>
    </select>
    <select id="queryByConfigKey" resultType="com.clougence.clouddm.platform.dal.model.system.DmSysEnvParamDO">
        select
        <include refid="rdpEnvParamList"/>
        from
        dm_sys_env_param
        <where>
            config_key in <foreach collection="configKeys" item="item" separator="," open="(" close=")">#{item}</foreach>
        </where>
    </select>
</mapper>
