<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.secrule.DmSecSpecMapper">

    <resultMap id="dmSecSpecDO" type="com.clougence.clouddm.platform.dal.model.secrule.DmSecSpecDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="owner_uid" property="ownerUid"/>
        <result column="spec_name" property="name"/>
        <result column="description" property="description"/>
        <result column="enable" property="enable"/>
    </resultMap>

    <sql id="allColumns">
        id,
        gmt_create,
        gmt_modified,
        owner_uid,
        spec_name,
        description,
        enable
    </sql>

    <select id="searchSpec" resultMap="dmSecSpecDO">
        SELECT
            <include refid="allColumns"/>
        FROM
            dm_sec_spec
        WHERE
            owner_uid = #{ownerUid}
            <if test="searchKeywords != null">AND (spec_name like concat('%',#{searchKeywords},'%') or description like concat('%',#{searchKeywords},'%'))</if>
        order by
            gmt_create desc
    </select>

    <select id="queryByIdAndUid" resultMap="dmSecSpecDO">
        SELECT
            <include refid="allColumns"/>
        FROM
            dm_sec_spec
        WHERE
            owner_uid = #{ownerUid} AND id = #{specId}
        limit 1
    </select>

    <select id="queryByIds" resultMap="dmSecSpecDO">
        SELECT
            <include refid="allColumns"/>
        FROM
            dm_sec_spec
        WHERE
            owner_uid = #{ownerUid} AND
            id in <foreach collection="ids" item="item" separator="," open="(" close=")">#{item}</foreach>
    </select>

    <select id="queryByUid" resultType="com.clougence.clouddm.platform.dal.model.secrule.DmSecSpecDO">
        SELECT
        <include refid="allColumns"/>
        FROM
        dm_sec_spec
        WHERE
        owner_uid = #{ownerUid}
    </select>

    <delete id="deleteByUidAndId">
        DELETE FROM
            dm_sec_spec
        WHERE
            owner_uid = #{ownerUid} AND id = #{specId}
        limit 1
    </delete>

    <update id="enableSpec">
        update
            dm_sec_spec
        set
            enable      = 1,
            gmt_modified= now()
        where
            owner_uid = #{ownerUid} AND id = #{specId}
        limit 1
    </update>

    <update id="disableSpec">
        update
            dm_sec_spec
        set
            enable      = 0,
            gmt_modified= now()
        where
            owner_uid = #{ownerUid} AND id = #{specId}
        limit 1
    </update>

    <update id="updateInfo">
        update
            dm_sec_spec
        set
            spec_name   = #{newName},
            description = #{newDesc},
            gmt_modified= now()
        where
            owner_uid = #{ownerUid} AND id = #{specId}
        limit 1
    </update>
</mapper>