<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.system.DmSysUserConfMapper">

    <resultMap id="rdpUserKvBaseConfigDO" type="com.clougence.clouddm.platform.dal.model.system.DmSysUserConfDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="uid" property="uid"/>
        <result column="config_name" property="configName"/>
        <result column="config_value" property="configValue"/>
        <result column="default_value" property="defaultValue"/>
        <result column="value_range" property="valueRange"/>
        <result column="read_only" property="readOnly"/>
        <result column="user_config_tag_type" property="userConfigTagType"
                javaType="com.clougence.clouddm.platform.dal.model.system.UserConfigTagType"/>
        <result column="conf_val_type" property="confValType"
                javaType="com.clougence.clouddm.platform.dal.model.system.KvConfValType"/>
        <result column="conf_belong" property="confBelong"
                javaType="com.clougence.clouddm.platform.dal.model.system.ConfBelong"/>
        <result column="is_secret" property="isSecret"/>
        <result column="desc_key" property="descKey"/>
    </resultMap>

    <sql id="rdpUserKvBaseConfig">
        id,
        gmt_create,
        gmt_modified,
        uid,
        config_name,
        config_value,
        default_value,
        value_range,
        read_only,
        user_config_tag_type,
        conf_val_type,
        conf_belong,
        is_secret,
        desc_key
    </sql>

    <select id="queryByUidAndConfigName" resultMap="rdpUserKvBaseConfigDO">
        SELECT
        <include refid="rdpUserKvBaseConfig"/>
        FROM
        dm_sys_user_conf
        WHERE
        uid = #{uid}
        AND
        config_name = #{configName}
    </select>

    <select id="listOneConfigTypeByUid" resultMap="rdpUserKvBaseConfigDO">
        SELECT
        <include refid="rdpUserKvBaseConfig"/>
        FROM
        dm_sys_user_conf
        WHERE
        uid = #{uid} and user_config_tag_type = #{type}
    </select>

    <select id="listByUid" resultMap="rdpUserKvBaseConfigDO">
        SELECT
        <include refid="rdpUserKvBaseConfig"/>
        FROM
        dm_sys_user_conf
        WHERE
        uid = #{uid}
    </select>

    <select id="listByUidAndConfigNames" resultMap="rdpUserKvBaseConfigDO">
        SELECT
        <include refid="rdpUserKvBaseConfig"/>
        FROM
        dm_sys_user_conf
        WHERE
        uid = #{uid}
        AND config_name in
        <foreach collection="configNames" item="item" separator="," open="(" close=")">
            #{item}
        </foreach>
    </select>

    <update id="updateUserConfig">
        UPDATE
            dm_sys_user_conf
        SET config_value = #{configValue}
        WHERE uid = #{uid}
          AND config_name = #{configName}
    </update>

    <delete id="deleteUserConfigs">
        DELETE
        FROM dm_sys_user_conf
        WHERE uid = #{uid}
    </delete>
</mapper>
