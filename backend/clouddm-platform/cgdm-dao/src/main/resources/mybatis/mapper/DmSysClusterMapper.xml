<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.platform.dal.mapper.system.DmSysClusterMapper">
    <resultMap id="clusterDO" type="com.clougence.clouddm.platform.dal.model.system.DmSysClusterDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="cluster_name" property="clusterName"/>
        <result column="region" property="region"/>
        <result column="cloud_or_idc_name" property="cloudOrIdcName"
                javaType="com.clougence.clouddm.platform.dal.model.system.CloudOrIdcName"/>
        <result column="cluster_desc" property="clusterDesc"/>
        <result column="uid" property="uid"/>
    </resultMap>

    <sql id="cluster">
        id,
        gmt_create,
        gmt_modified,
        cluster_name,
        region,
        cloud_or_idc_name,
        cluster_desc,
        uid
    </sql>

    <update id="updateClusterDesc" parameterType="com.clougence.clouddm.platform.dal.model.system.DmSysClusterDO">
        UPDATE
            dm_sys_cluster
        set
            cluster_desc = #{clusterDesc}
        WHERE
            id = #{id}
    </update>

    <select id="queryById" resultMap="clusterDO">
        SELECT
            <include refid="cluster"/>
        FROM
            dm_sys_cluster
        WHERE
            id = #{resId}
        limit 1
    </select>

    <select id="listByIds" resultMap="clusterDO">
        SELECT
            <include refid="cluster"/>
        FROM
            dm_sys_cluster
        WHERE
            id in <foreach collection="ids" item="item" separator="," open="(" close=")">#{item}</foreach>
    </select>

    <select id="listByCondition" resultMap="clusterDO">
        SELECT
            <include refid="cluster"/>
        FROM
            dm_sys_cluster
        WHERE
            uid = #{ownerUid}
            <if test="clusterName != null">
                AND cluster_name LIKE concat('%',#{clusterName},'%')
            </if>
            <if test="cloudOrIdcName != null">
                AND cloud_or_idc_name = #{cloudOrIdcName,javaType=com.clougence.clouddm.platform.dal.model.system.CloudOrIdcName}
            </if>
            <if test="region != null">
                AND region = #{region}
            </if>
            <if test="clusterDesc != null">
                AND cluster_desc LIKE concat('%',#{clusterDesc},'%')
            </if>
        order by gmt_create desc
    </select>

    <select id="getClusterByName" resultMap="clusterDO">
        SELECT
            <include refid="cluster"/>
        FROM
            dm_sys_cluster
        WHERE
            cluster_name = #{clusterName}
    </select>
</mapper>
